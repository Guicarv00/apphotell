<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="apphotell.MainPage"
             BackgroundColor="#F2F2F2">

    <ScrollView>

        <VerticalStackLayout Padding="25" Spacing="15">

            <Label Text="APP HOTEL"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="Black"/>

            <Image Source="hotel.png"
                   HeightRequest="200"
                   HorizontalOptions="Center"/>

            <Entry Placeholder="Nome do hóspede"
                   TextColor="Black"/>

            <Entry Placeholder="Quantidade de hóspedes"
                   Keyboard="Numeric"
                    TextColor="Black"/>
            

            <DatePicker Format="dd/MM/yyyy"/>

            <Picker Title="Tipo de quarto"
        TextColor="White"
        TitleColor="Black"
        BackgroundColor="Gray" 
        SelectedItem="{Binding TipoQuarto, Mode=TwoWay}">
                <Picker.Items>
                    <x:String>Simples</x:String>
                    <x:String>Luxo</x:String>
                    <x:String>Premium</x:String>
                </Picker.Items>
            </Picker>

            <Stepper Minimum="1"
                     Maximum="10"
                     Increment="1"/>

            <Button Text="Reservar"
                    Clicked="OnReservarClicked"
                    BackgroundColor="DarkBlue"
                    TextColor="White"
                    CornerRadius="15"/>

            <Button Text="Sobre"
                    Clicked="Sobre_Clicked"
                    BackgroundColor="Red"
                    TextColor="White"
                    CornerRadius="15"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>