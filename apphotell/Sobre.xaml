<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="apphotell.Sobre"
             Title="Sobre"
             BackgroundColor="White">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Sobre o Aplicativo"
               FontSize="30"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="Black"/>

        <Label Text="ℹ️"
               FontSize="80"
               HorizontalOptions="Center"/>

        <Label Text="Aplicativo: AppHotel"
               FontSize="22"
               TextColor="Black"/>

        <Label Text="Desenvolvedor: Guilherme Carvalho"
               FontSize="20"
               TextColor="Black"/>

        <Label Text="Ano de desenvolvimento: 2026"
               FontSize="20"
               TextColor="Black"/>

        <Button Text="Voltar"
                Clicked="Voltar_Clicked"
                BackgroundColor="Yellow"
                TextColor="Black"
                CornerRadius="15"/>

    </VerticalStackLayout>

</ContentPage>